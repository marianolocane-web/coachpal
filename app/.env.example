# Supabase project credentials (Project Settings -> API in the Supabase dashboard)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Diario AI — server-side only (used by app/api/*, never exposed to the browser).
# Get these from console.anthropic.com, console.groq.com and dashboard.voyageai.com.
ANTHROPIC_API_KEY=your-anthropic-api-key
GROQ_API_KEY=your-groq-api-key
VOYAGE_API_KEY=your-voyage-api-key

# Diario AI via Telegram — server-side only.
# Bot token/username from @BotFather; the webhook secret is any random string
# you choose yourself (used to verify incoming requests are really from Telegram).
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=any-random-string-you-choose

# Service-role key (Project Settings -> API -> service_role), used only by
# api/telegram-webhook.ts since it has no user session to scope RLS with.
# Never expose this to the browser — server-side only, bypasses RLS entirely.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Client-side: the bot's @username, used to build the t.me deep link shown
# in Perfil -> "Conectar Telegram". Bot usernames are public, safe to expose.
VITE_TELEGRAM_BOT_USERNAME=YourBotUsername
